      "Bash(uv pip:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(.specify/scripts/bash/*)"
