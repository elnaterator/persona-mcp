      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(date:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(sed -i:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(git:*)",
      "Bash(git worktree:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(lsof -ti:*)",
      "Bash(ps:*)",
      "Bash(grep:*)",
      "Bash(cd:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(mkdir -p:*)",
      "Bash(mv:*)",
