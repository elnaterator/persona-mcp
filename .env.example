# Clerk configuration — get these from your Clerk dashboard
# https://dashboard.clerk.com → Your App → API Keys
# Note: the JWKS URL and Issuer will be in the format https://<your-clerk-app>.clerk.accounts.dev
CLERK_JWKS_URL=https://<your-clerk-app>.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-app>.clerk.accounts.dev
# The webhook secret is used to verify that incoming webhooks are actually from Clerk. You can find this in your Clerk dashboard under Webhooks.
CLERK_WEBHOOK_SECRET=whsec_...